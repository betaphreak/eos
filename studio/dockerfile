# ==========================================
# STAGE 1: Build Environment
# ==========================================
FROM node:22-alpine AS build

# Install OS dependencies required by 'sharp' (Strapi's image processing library)
RUN apk update && apk add --no-cache build-base gcc autoconf automake zlib-dev libpng-dev vips-dev > /dev/null 2>&1

# Use sharp's PREBUILT musl binaries (@img/sharp-linuxmusl-*) instead of compiling it.
#
# sharp prefers a global libvips when it finds one that satisfies its minimum — and `vips-dev` above
# puts one on the image. That flipped sharp 0.34 (which Strapi 5.50 brought in) into a from-source
# node-gyp build, which then fails outright: "sharp: Please add node-addon-api to your dependencies".
# The prebuilt binaries bundle their own libvips and are already in the lockfile, so the honest fix is
# to stop letting the system copy win. Set before `npm ci` — sharp decides at install time.
ENV SHARP_IGNORE_GLOBAL_LIBVIPS=1

# Set to production so Strapi optimizes the Admin UI build
ENV NODE_ENV=production

# Install dependencies first (caching layer)
WORKDIR /opt/
COPY package.json package-lock.json ./
RUN npm ci --omit=dev

# Set path to include node_modules
ENV PATH=/opt/node_modules/.bin:$PATH

# Copy project files and build the Admin UI. The Vite admin build is memory-hungry; raise V8's heap
# ceiling so it doesn't OOM inside a memory-constrained builder (Rancher/Docker Desktop VM) — CI
# runners have more RAM but the setting is harmless there.
ENV NODE_OPTIONS=--max-old-space-size=4096
WORKDIR /opt/app
COPY . .
RUN npm run build

# ==========================================
# STAGE 2: Production Environment
# ==========================================
FROM node:22-alpine

# Re-install libvips so sharp works at runtime
RUN apk add --no-cache vips-dev

ENV NODE_ENV=production
WORKDIR /opt/app

# Copy the built node_modules and app files from Stage 1
COPY --from=build /opt/node_modules ./node_modules
COPY --from=build /opt/app ./
ENV PATH=/opt/node_modules/.bin:$PATH

# Secure the container by running as a non-root user
RUN chown -R node:node /opt/app
USER node

# Expose Strapi's default port
EXPOSE 1337

# Start Strapi
CMD ["npm", "run", "start"]