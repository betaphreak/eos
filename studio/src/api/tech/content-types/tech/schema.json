{
  "kind": "collectionType",
  "collectionName": "techs",
  "info": {
    "singularName": "tech",
    "pluralName": "techs",
    "displayName": "Tech",
    "description": "A technology-tree node (C2C). Era is an enum attribute; And/Or prerequisites are self-relations."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "key": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": false } },
      "required": true,
      "unique": true
    },
    "name": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } },
      "required": true
    },
    "help": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "quote": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "description": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "civilopedia": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "advisor": {
      "type": "enumeration",
      "pluginOptions": { "i18n": { "localized": false } },
      "enum": [
        "ADVISOR_GROWTH",
        "ADVISOR_ECONOMY",
        "ADVISOR_MILITARY",
        "ADVISOR_SCIENCE",
        "ADVISOR_CULTURE",
        "ADVISOR_RELIGION"
      ]
    },
    "era": {
      "type": "enumeration",
      "pluginOptions": { "i18n": { "localized": false } },
      "enum": [
        "PREHISTORIC",
        "ANCIENT",
        "CLASSICAL",
        "MEDIEVAL",
        "RENAISSANCE",
        "INDUSTRIAL",
        "ATOMIC",
        "INFORMATION",
        "NANOTECH",
        "TRANSHUMAN"
      ]
    },
    "cost": {
      "type": "integer",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "gridX": {
      "type": "integer",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "gridY": {
      "type": "integer",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "trade": {
      "type": "boolean",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "goodyTech": {
      "type": "boolean",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "sound": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "button": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "flavors": {
      "type": "json",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "andPreReqs": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tech.tech"
    },
    "orPreReqs": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tech.tech"
    },
    "unlockedBuildings": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::building.building",
      "mappedBy": "prereqTech"
    },
    "unlockedUnits": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::unit.unit",
      "mappedBy": "prereqTech"
    }
  }
}
