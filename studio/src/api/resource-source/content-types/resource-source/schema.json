{
  "kind": "collectionType",
  "collectionName": "resource_sources",
  "info": {
    "singularName": "resource-source",
    "pluralName": "resource-sources",
    "displayName": "Resource Source",
    "description": "A base (C2C tier-1) resource producer — output bonus + gatherers."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "key": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "output": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::bonus.bonus"
    },
    "gatherers": {
      "type": "json"
    }
  }
}
