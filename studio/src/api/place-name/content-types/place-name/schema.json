      "unique": true
    },
    "name": {
      "type": "string",
      "required": true
    },
    "countryCode": {
      "type": "string"
    },
    "latitude": {
      "type": "decimal"
    },
    "longitude": {
      "type": "decimal"
    },
    "elevation": {
      "type": "integer"
    },
    "featureClass": {
      "type": "string"
    }
  }
}
