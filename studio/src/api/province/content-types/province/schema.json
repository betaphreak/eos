{
  "kind": "collectionType",
  "collectionName": "provinces",
  "info": {
    "singularName": "province",
    "pluralName": "provinces",
    "displayName": "Province",
    "description": "An imported Anbennar EU4 province — the world-map hub entity."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "provinceId": {
      "type": "integer",
      "pluginOptions": { "i18n": { "localized": false } },
      "required": true,
      "unique": true,
      "min": 0
    },
    "name": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } },
      "required": true
    },
    "latitude": {
      "type": "decimal",
      "pluginOptions": { "i18n": { "localized": false } },
      "min": -90,
      "max": 90
    },
    "longitude": {
      "type": "decimal",
      "pluginOptions": { "i18n": { "localized": false } },
      "min": -180,
      "max": 180
    },
    "plots": {
      "type": "integer",
      "pluginOptions": { "i18n": { "localized": false } },
      "default": 0,
      "min": 0
    },
    "waterPlots": {
      "type": "integer",
      "pluginOptions": { "i18n": { "localized": false } },
      "default": 0,
      "min": 0
    },
    "type": {
      "type": "enumeration",
      "pluginOptions": { "i18n": { "localized": false } },
      "default": "LAND",
      "enum": [
        "LAND",
        "CAVERN",
        "DWARVEN_HOLD",
        "DWARVEN_HOLD_SURFACE",
        "DWARVEN_ROAD",
        "ANCIENT_FOREST",
        "GLADEWAY",
        "FEY_GLADEWAY",
        "BLOODGROVES",
        "MUSHROOM_FOREST",
        "SHADOW_SWAMP",
        "GLACIER",
        "SEA",
        "LAKE",
        "IMPASSABLE"
      ]
    },
    "continent": {
      "type": "enumeration",
      "pluginOptions": { "i18n": { "localized": false } },
      "enum": [
        "europe",
        "serpentspine",
        "asia",
        "africa",
        "north_america",
        "south_america",
        "oceania"
      ]
    },
    "realm": {
      "type": "enumeration",
      "pluginOptions": { "i18n": { "localized": false } },
      "enum": [
        "halcann",
        "aelantir",
        "hinuilands"
      ]
    },
    "winter": {
      "type": "enumeration",
      "pluginOptions": { "i18n": { "localized": false } },
      "enum": ["mild", "normal", "severe"]
    },
    "monsoon": {
      "type": "enumeration",
      "pluginOptions": { "i18n": { "localized": false } },
      "enum": ["mild", "normal", "severe"]
    },
    "climate": {
      "type": "enumeration",
      "pluginOptions": { "i18n": { "localized": false } },
      "enum": ["arctic", "arid", "tropical"]
    },
    "baseTax": {
      "type": "integer",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "baseProduction": {
      "type": "integer",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "baseManpower": {
      "type": "integer",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "city": {
      "type": "boolean",
      "pluginOptions": { "i18n": { "localized": false } },
      "default": false
    },
    "owner": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::country.country"
    },
    "controller": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::country.country"
    },
    "culture": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::culture.culture"
    },
    "religion": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::religion.religion"
    },
    "tradeGood": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::trade-good.trade-good"
    },
    "area": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::area.area"
    },
    "region": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::region.region"
    },
    "neighbors": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::province.province",
      "inversedBy": "isNeighborOf"
    },
    "isNeighborOf": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::province.province",
      "mappedBy": "neighbors"
    }
  }
}
