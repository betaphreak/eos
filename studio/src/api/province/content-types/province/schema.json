{
  "kind": "collectionType",
  "collectionName": "provinces",
  "info": {
    "singularName": "province",
    "pluralName": "provinces",
    "displayName": "Province"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "provinceId": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "required": true,
      "unique": true,
      "min": 0,
      "max": 9999
    },
    "name": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "minLength": 1,
      "maxLength": 127,
      "required": true,
      "unique": false
    },
    "plots": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "required": true,
      "default": 0,
      "min": 0,
      "max": 100000
    },
    "r": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "required": true,
      "min": 0,
      "max": 255
    },
    "g": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "required": true,
      "min": 0,
      "max": 255
    },
    "b": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "required": true,
      "min": 0,
      "max": 255
    },
    "hexCode": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "default": "INVALID",
      "minLength": 7,
      "maxLength": 7,
      "required": true,
      "unique": false
    },
    "neighbors": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::province.province",
      "inversedBy": "isNeighborOf"
    },
    "isNeighborOf": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::province.province",
      "mappedBy": "neighbors"
    },
    "minX": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "required": false,
      "min": 0
    },
    "minY": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "min": 0
    },
    "maxX": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "min": 0
    },
    "maxY": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "min": 0
    },
    "svgOuterBound": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "required": true
    },
    "latitude": {
      "type": "decimal",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "required": true,
      "min": -90,
      "max": 90
    },
    "provinceArea": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::province-area.province-area",
      "inversedBy": "provinces"
    },
    "provinceType": {
      "type": "enumeration",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "required": true,
      "default": "LAND",
      "enum": [
        "LAND",
        "SEA",
        "LAKE",
        "WASTELAND"
      ]
    },
    "waterPlots": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "default": 0
    },
    "sprite": {
      "type": "media",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "multiple": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    }
  }
}
