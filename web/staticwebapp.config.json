{
  "mimeTypes": {
    ".pack": "application/octet-stream",
    ".mjs": "text/javascript",
    ".woff2": "font/woff2"
  },
  "routes": [
    {
      "route": "/assets/*",
      "headers": {
        "Cache-Control": "public, max-age=3600"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/js/*", "*.js", "*.mjs", "*.css", "*.png", "*.pack"]
  }
}
