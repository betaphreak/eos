# Project exclude paths
/target/
/out/
/output/
/eos.iml
/.idea/.gitignore
/.idea/misc.xml
/.idea/modules.xml
/.idea/vcs.xml
/.idea/
/.claude/
/full.log
# derived, regenerable web copy of per-province plot grids (build.mjs → shipPlots)
/web/assets/plots/
# derived, regenerable high-res terrain-texture atlas (build.mjs → bakeTerrainTiles)
/web/assets/terrain-tiles-*.png
# whole-world per-province plot caches — hundreds of MB, canonical/regenerable via
# WorldPlotGenerator (the sim also regenerates any on demand). Too heavy to commit.
/src/main/resources/map/provinces/*.json.gz
