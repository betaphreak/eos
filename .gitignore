# Project exclude paths
/target/
/out/
/output/
/eos.iml
/.idea/.gitignore
/.idea/misc.xml
/.idea/modules.xml
/.idea/vcs.xml
/.idea/
/.claude/
/full.log
# webverify browser-test tooling deps (regenerable via `npm install`)
/tools/webverify/node_modules/
/tools/webverify/package-lock.json
# NOTE: the baked web assets (web/assets/*.png, web/assets/plots.pack) are COMMITTED, non-LFS —
# ~20 MB total, regenerated by `node web/build.mjs` and checked in, so the Azure SWA deploy uploads
# the prebuilt web/ folder as-is instead of rebuilding (see .github/workflows/deploy-web.yml).
# Only the heavy build *inputs* stay out of git:
# whole-world per-province plot caches — hundreds of MB, canonical/regenerable via
# WorldPlotGenerator (the sim also regenerates any on demand). Too heavy to commit.
/src/main/resources/map/provinces/*.json.gz
# derived .nif render sprites (the explored alternative to GameFont — docs/bonus-sprite-bake.md)
/tools/nif-bake/out/
