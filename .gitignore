# Project exclude paths
/target/
/out/
/output/
/eos.iml
/.idea/.gitignore
/.idea/misc.xml
/.idea/modules.xml
/.idea/vcs.xml
/.idea/
/.claude/
/full.log
# webverify browser-test tooling deps (regenerable via `npm install`)
/tools/webverify/node_modules/
/tools/webverify/package-lock.json
# derived, regenerable packed per-province plot grids (build.mjs → packPlots)
/web/assets/plots.pack
/web/assets/plots/
# derived, regenerable high-res terrain-texture atlas (build.mjs → bakeTerrainTiles)
/web/assets/terrain-tiles-*.png
# derived, regenerable water tile for the river ribbon (build.mjs → bakeRiverTile)
/web/assets/river-*.png
# derived, regenerable coastscalemask blend atlas (build.mjs → bakeCoastTiles)
/web/assets/coast-*.png
# whole-world per-province plot caches — hundreds of MB, canonical/regenerable via
# WorldPlotGenerator (the sim also regenerates any on demand). Too heavy to commit.
/src/main/resources/map/provinces/*.json.gz
