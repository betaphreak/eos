# Project exclude paths
/target/
civstudio-engine/target/
civstudio-server/target/
/out/
/output/
/eos.iml
/.idea/.gitignore
/.idea/misc.xml
/.idea/modules.xml
/.idea/vcs.xml
/.idea/
/.claude/
/full.log
# webverify browser-test tooling deps (regenerable via `npm install`)
/tools/webverify/node_modules/
/tools/webverify/package-lock.json
# web build tooling deps (sharp — the WebP image encoder; regenerable via `npm install`)
/web/node_modules/
/web/package-lock.json
# NOTE: the baked web assets (web/assets/*.png, web/assets/plots.pack) are COMMITTED, non-LFS —
# ~20 MB total, regenerated by `node web/build.mjs` and checked in, so the Azure SWA deploy uploads
# the prebuilt web/ folder as-is instead of rebuilding (see .github/workflows/deploy-web.yml).
# Only the heavy build *inputs* stay out of git:
# whole-world per-province plot caches — hundreds of MB, canonical/regenerable via
# WorldPlotGenerator (the sim also regenerates any on demand). Too heavy to commit.
/civstudio-engine/src/main/resources/map/provinces/*.json.gz
# derived .nif render sprites (the explored alternative to GameFont — docs/bonus-sprite-bake.md)
/tools/nif-bake/out/
# vendored Anbennar EU4 political history — build-time inputs for the political-map exporters
# (ProvinceHistoryExporter / Country|Culture|ReligionExporter). Thousands of small files; kept OUT
# of git. The *derived* map/{countries,cultures,religions}.json + owner-stamped provinces.json ARE
# committed. To re-run the exporters, re-checkout these from gitlab.com/anbennar/anbennar-eu4-dev
# (new-master). See docs/political-map.md.
/data/anbennar/history/
/data/anbennar/common/
# vendored Anbennar loading-screen art (.dds) — baked to web/assets/loading-*.jpg (committed) by
# web/bake-loading.mjs. Raw art kept out of git; re-download from the mod to re-bake.
/data/anbennar/loadingscreens/
