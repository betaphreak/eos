# Project exclude paths
/target/
civstudio-engine/target/
civstudio-server/target/
/out/
/output/
/eos.iml
/.idea/.gitignore
/.idea/misc.xml
/.idea/modules.xml
/.idea/vcs.xml
/.idea/
/.claude/
/full.log
# webverify browser-test tooling deps (regenerable via `npm install`)
/tools/webverify/node_modules/
/tools/webverify/package-lock.json
# web build tooling deps (sharp — the WebP image encoder; regenerable via `npm install`)
/web/node_modules/
/web/package-lock.json
# NOTE: the baked web assets (web/assets/*.png, web/assets/plots.pack) are COMMITTED, non-LFS —
# ~20 MB total, regenerated by `node web/build.mjs` and checked in, so the Azure SWA deploy uploads
# the prebuilt web/ folder as-is instead of rebuilding (see .github/workflows/deploy-web.yml).
# Only the heavy build *inputs* stay out of git:
# whole-world per-province plot caches — hundreds of MB, canonical/regenerable via
# WorldPlotGenerator (the sim also regenerates any on demand). Too heavy to commit.
/civstudio-engine/src/main/resources/map/provinces/*.json.gz
# non-human race name tables — generated on demand from the Anbennar cultures file (RaceNameGenerator)
# and cached here by NameStore; only the hand-authored /human-names/ set is committed. Regenerable, so
# out of git. See docs/names.md.
/civstudio-engine/src/main/resources/generated/names/
# derived .nif render sprites (the explored alternative to GameFont — docs/bonus-sprite-bake.md)
/tools/nif-bake/out/
# Anbennar EU4 mod files are no longer vendored. They are fetched on demand from GitLab (pinned by
# anbennar-source.lock) into a local cache by com.civstudio.data.AnbennarFiles — the *derived*
# map/*.json resources stay committed. See docs/anbennar-files.md. Ignore the cache + any leftover
# local checkout of the old vendored tree.
/.anbennar-cache/
/data/anbennar/

# Caveman2Cosmos (Civ4) art/XML — likewise no longer vendored. Fetched on demand from the C2C GitHub
# repo (pinned by civ4-source.lock) into a local cache by com.civstudio.data.Civ4Files (+ the
# web/civ4.mjs node sibling); dev-time only (nothing at runtime reads it). See docs/civ4-files.md.
/.civ4-cache/

# Server plot-grid cache — generated on demand, cached to a (persistent, in prod) volume. See
# docs/plot-serving.md.
/.plot-cache/

# webverify screenshot artifacts
/tools/webverify/*.png
